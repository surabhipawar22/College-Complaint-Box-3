{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/static/$1" },
    { "src": "/submit_complaint", "dest": "/api/index.py" },
    { "src": "/complaints",       "dest": "/api/index.py" },
    { "src": "/resolve/(.*)",     "dest": "/api/index.py" },
    { "src": "/delete/(.*)",      "dest": "/api/index.py" },
    { "src": "/admin/login",      "dest": "/api/index.py" },
    { "src": "/admin",            "dest": "/api/index.py" },
    { "src": "/(.*)",             "dest": "/api/index.py" }
  ]
}
