# ─────────────────────────────────────────────────────────────────────────────
#  .env  — LOCAL DEVELOPMENT ONLY
#  Copy this file:   cp .env.example .env
#  Fill in your values. NEVER commit the real .env to Git.
#
#  For Vercel, set the same keys in:
#  Vercel Dashboard → Your Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# Supabase PostgreSQL connection URI
# Get it from: Supabase → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Admin panel credentials (change before deploying!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_use_a_strong_password
